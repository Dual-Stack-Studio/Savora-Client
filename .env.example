# Copy the relevant lines into .env.local (gitignored) and fill in your values.

# Backend URL (see ../nicy-kitchen-api). Defaults to localhost (web/iOS) or
# 10.0.2.2 (Android emulator). Set this to your machine's LAN IP to test on
# a physical phone with Expo Go, e.g.:
# EXPO_PUBLIC_API_URL=http://192.168.0.10:3000

# Google Sign-In web client ID.
# Google Cloud Console -> APIs & Services -> Credentials -> Create Credentials
# -> OAuth client ID -> Application type: "Web application".
# Works out of the box with `npm run web`. It does NOT work inside Expo Go
# on a physical phone (Google rejects the dynamic exp:// redirect) — the
# Account screen will show a clear message in that case.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
